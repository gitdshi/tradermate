# TraderMate 环境变量配置示例
# 复制此文件为 .env 并填入真实值
# 切勿将 .env 文件提交到版本控制！

# 基础环境
ENVIRONMENT=production
DEBUG=False
API_PORT=8000
MYSQL_PORT=3306
REDIS_PORT=6379

# MySQL 配置
MYSQL_ROOT_PASSWORD=your-root-password-here
MYSQL_DATABASE=tradermate
MYSQL_USER=tradermate
MYSQL_PASSWORD=your-mysql-password-here

# JWT 配置
JWT_SECRET_KEY=your-jwt-secret-key-change-this-to-a-random-string

# Tushare API 配置
TUSHARE_TOKEN=your-tushare-token-here

# Redis 配置
REDIS_URL=redis://localhost:6379/0
